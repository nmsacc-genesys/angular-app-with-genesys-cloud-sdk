{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "composite": true,
    "declaration": true,
    "types": [
      "vitest/globals"
    ]
  },
  "references": [
    { "path": "./tsconfig.app.json" }
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/main.ts"
  ]
}
